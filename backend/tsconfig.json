{
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "./dist",
		"lib": ["ES2022"],
		"target": "esnext",
		"module": "esnext",
		"esModuleInterop": true,
		"moduleResolution": "node",
		"strict": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "tests"]
}
